rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Accounts
    match /accounts/{accountId} {
      allow read: if request.auth.uid in resource.data.users;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.users;
      allow update: if request.auth.uid in resource.data.users
                    && (request.resource.data.ownerUser.uid == resource.data.ownerUser.uid 
                    || request.auth.uid == resource.data.ownerUser.uid);
      allow delete: if request.auth.uid == resource.data.ownerUser.uid;
    }

    // All subcollections under an account
    match /accounts/{accountId}/{document=**} {
      allow read, write, delete:
        if request.auth.uid in get(/databases/$(database)/documents/accounts/$(accountId)).data.users;
    }

    // Contact Requests (public create, no read/update/delete)
    match /contactRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Welcome Emails (admin-only create, no public access)
    match /welcomeEmails/{emailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Users (read-only to authed users; self-managed writes)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid; 
    }
  }
}
